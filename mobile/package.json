{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env CI=false expo start --dev-client",
    "android": "expo run:android",
    "android:start": "cross-env CI=false expo start --android --dev-client",
    "android:prebuild": "expo prebuild --platform android --clean",
    "ios": "expo run:ios",
    "web": "cross-env CI=false expo start --web",
    "web:clear": "cross-env CI=false expo start --web --clear",
    "web:ci": "cross-env CI=true expo export --platform web --output-dir dist-web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "~54.0.10",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-linear-gradient": "~15.0.8",
    "expo-network": "~8.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-udp": "^4.1.7",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
